# ────────────────────────────────────────────────────────────
# Seedance Local Studio — 환경변수 예시 파일
# ────────────────────────────────────────────────────────────
#
# 사용 방법:
#   1. 이 파일을 복사하여 .env 로 저장합니다
#      cp .env.example .env
#   2. .env 파일에 실제 API 키를 입력합니다
#   3. .env 파일은 절대 git에 커밋하지 마세요 (.gitignore에 포함됨)
#
# API 키 발급:
#   Atlas Cloud 콘솔 → https://www.atlascloud.ai/settings/api-keys
# ────────────────────────────────────────────────────────────

# Atlas Cloud API 키 (필수)
ATLAS_API_KEY=your_atlas_cloud_api_key_here
